# Firebase Web App config used by scripts/generate-env.js.
# Create these values in Firebase Console > Project settings > Your apps > Web app.
FISHBOWL_FIREBASE_API_KEY=your-api-key
FISHBOWL_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FISHBOWL_FIREBASE_PROJECT_ID=your-project-id
FISHBOWL_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FISHBOWL_FIREBASE_MESSAGING_SENDER_ID=1234567890
FISHBOWL_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Public URL of the deployed frontend, used to generate QR join links.
FISHBOWL_PUBLIC_URL=https://your-site.example.com
